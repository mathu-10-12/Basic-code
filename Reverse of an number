import java.util.*;
class MainJava{
    public static void main(String arg[]){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int d=n;
        int i=0,rev=0;
        while(n>0){
            d=n%10;
            rev=rev*10+d;
            n=n/10;
            i++;
        }
        System.out.println(rev);
    }
}
