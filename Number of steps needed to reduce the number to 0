import java.util.*;
class Main{
    public static void main(String arg[]){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int step=0;
        while(n!=0){
         if(n%2==0){
             n=n/2;
         }
          else{
              n=n-1;
          }
            step++;
        }
           System.out.println(step);
    }
}
