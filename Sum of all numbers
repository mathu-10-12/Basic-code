import java.util.*;
class MainJava{
    public static void main(String arg[]){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int a=n;
        int i=0,sum=0;
        while(n>0){
            a=n%10;
            sum+=a;
            n=n/10;
            i++;
        }
        System.out.println(sum);
        
    }
}
