import java.util.*;
class Main{
    public static void main(String arg[]){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int c=0;
        for(int i=1;i<n/2+1;i++){
         if((n%i)==0){
             c++;
         }
        }
        if(c==3){
        System.out.println(n+" has three divisors");
    }
         else{
           System.out.println(n+" is not an three divisors");
    }
    }
}
